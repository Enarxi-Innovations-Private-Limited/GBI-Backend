generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  passwordHash      String?
  googleId          String?            @unique
  name              String?
  organization      String?
  phone             String?
  emailVerified     Boolean            @default(false)
  phoneVerified     Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  city              String?
  isRestricted      Boolean            @default(false)
  isProfileComplete Boolean            @default(false)
  assignments       DeviceAssignment[]
  deviceGroups      DeviceGroup[]
  eventLogs         EventLog[]
  notifications     Notification[]
  refreshTokens     RefreshToken[]

  isPremium     Boolean   @default(false)     // For Phase 2 gating
  premiumExpiry DateTime?                    // For Expiry Logic
  transactions  PaymentTransaction[]
}

model SubscriptionPlan {
  id            String   @id @default(uuid())
  name          String   @unique             // e.g., "Premium Monthly"
  price         Float                        // Admin Pricing Control
  durationDays  Int                          // Expiry Logic helper
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model PaymentTransaction {
  id                    String            @id @default(uuid())
  merchantTransactionId String            @unique 
  amount                Float
  status                TransactionStatus @default(PENDING)
  provider              String             // "RAZORPAY" or "PHONEPE"
  userId                String
  user                  User              @relation(fields: [userId], references: [id])
  createdAt             DateTime          @default(now())
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

model Admin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Device {
  id              String             @id @default(uuid())
  deviceId        String             @unique
  status          DeviceStatus       @default(OFFLINE)
  addedAt         DateTime           @default(now())
  type            String             @default("Air Quality Monitor")
  lastHeartbeatAt DateTime?
  deletedAt       DateTime?
  isDeleted       Boolean            @default(false)
  groupId         String?
  group           DeviceGroup?       @relation(fields: [groupId], references: [id])
  assignments     DeviceAssignment[]
  telemetry       DeviceTelemetry[]
  deviceThreshold DeviceThreshold?
  logs            EventLog[]
}

model DeviceGroup {
  id        String          @id @default(uuid())
  name      String
  userId    String
  createdAt DateTime        @default(now())
  devices   Device[]
  user      User            @relation(fields: [userId], references: [id])
  threshold GroupThreshold?

  @@index([userId])
}

model DeviceAssignment {
  id           String    @id @default(uuid())
  deviceId     String
  userId       String
  assignedAt   DateTime  @default(now())
  unassignedAt DateTime?
  device       Device    @relation(fields: [deviceId], references: [id])
  user         User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([deviceId])
}

model UserDevice {
  id       String  @id @default(uuid())
  deviceId String
  userId   String
  name     String?
  location String?
  city     String?
  pincode  String?

  @@unique([deviceId, userId])
}

model DeviceTelemetry {
  id          BigInt   @id @default(autoincrement())
  deviceId    String
  timestamp   DateTime @default(now())
  pm25        Int?
  pm10        Int?
  tvoc        Int?
  co2         Int?
  temperature Float?
  humidity    Float?
  noise       Int?
  aqi         Int?
  device      Device   @relation(fields: [deviceId], references: [id])

  @@index([deviceId, timestamp])
}

model GroupThreshold {
  id         String      @id @default(uuid())
  groupId    String      @unique
  thresholds Json
  createdAt  DateTime    @default(now())
  group      DeviceGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model DeviceThreshold {
  id         String   @id @default(uuid())
  deviceId   String   @unique
  thresholds Json
  createdAt  DateTime @default(now())
  device     Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

model AlertState {
  id              String    @id @default(uuid())
  userId          String
  deviceId        String
  parameter       String
  state           String
  lastTriggeredAt DateTime?
  updatedAt       DateTime  @updatedAt

  @@unique([userId, deviceId, parameter])
}

model EventLog {
  id        BigInt   @id @default(autoincrement())
  deviceId  String
  userId    String?
  eventType String
  parameter String?
  value     Float?
  createdAt DateTime @default(now())
  device    Device   @relation(fields: [deviceId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])

  @@index([deviceId])
  @@index([userId])
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  deviceId  String?
  message   String
  createdAt DateTime  @default(now())
  isRead    Boolean   @default(false)
  readAt    DateTime?
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, isRead])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

enum DeviceStatus {
  ACTIVE
  WARNING
  OFFLINE
}
