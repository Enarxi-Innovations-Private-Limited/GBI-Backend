generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String               @id @default(uuid())
  email                String               @unique
  passwordHash         String?
  googleId             String?              @unique
  name                 String?
  organization         String?
  phone                String?
  emailVerified        Boolean              @default(false)
  phoneVerified        Boolean              @default(false)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  city                 String?
  isRestricted         Boolean              @default(false)
  isProfileComplete    Boolean              @default(false)
  isPremium            Boolean              @default(false)
  premiumStatus        PremiumStatus        @default(FREE)
  premiumExpiry        DateTime?
  assignments          DeviceAssignment[]
  deviceGroups         DeviceGroup[]
  eventLogs            EventLog[]
  notifications        Notification[]
  refreshTokens        RefreshToken[]
  Subscription         Subscription[]
  generatedReports     GeneratedReport[]
  premiumSubscriptions PremiumSubscription[]
  premiumHistory       PremiumHistory[]

  // Enables expireOverdueSubscriptions() to use an index scan instead of full table scan
  @@index([isPremium, premiumExpiry])
}

model Admin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Device {
  id              String             @id @default(uuid())
  deviceId        String             @unique
  status          DeviceStatus       @default(OFFLINE)
  addedAt         DateTime           @default(now())
  type            String             @default("Air Quality Monitor")
  lastHeartbeatAt DateTime?
  deletedAt       DateTime?
  isDeleted       Boolean            @default(false)
  groupId         String?
  group           DeviceGroup?       @relation(fields: [groupId], references: [id])
  assignments     DeviceAssignment[]
  telemetry       DeviceTelemetry[]
  deviceThreshold DeviceThreshold?
  logs            EventLog[]

  // Offline detector: status filter + heartbeat cutoff range scan
  @@index([isDeleted, status])
  @@index([isDeleted, lastHeartbeatAt])
  // Alert group threshold lookup — fixes correlated subquery → O(log N) join
  @@index([groupId])
}

model DeviceGroup {
  id        String          @id @default(uuid())
  name      String
  userId    String
  createdAt DateTime        @default(now())
  devices   Device[]
  user      User            @relation(fields: [userId], references: [id])
  threshold GroupThreshold?

  @@index([userId])
}

model DeviceAssignment {
  id           String    @id @default(uuid())
  deviceId     String
  userId       String
  assignedAt   DateTime  @default(now())
  unassignedAt DateTime?
  device       Device    @relation(fields: [deviceId], references: [id])
  user         User      @relation(fields: [userId], references: [id])

  @@index([userId, unassignedAt])
  // Combined index covers both the FK and the active-assignment filter in one scan
  @@index([deviceId, unassignedAt])
}

model UserDevice {
  id       String @id @default(uuid())
  deviceId String @unique
  userId   String
  name     String
  location String
  city     String
  pincode  String

  // Previously had NO indexes on userId — caused full table scans on every
  // report generation, event log listing, and admin device panel call.
  @@index([userId])
  @@index([userId, deviceId])
}

model DeviceTelemetry {
  id          BigInt   @id @default(autoincrement())
  deviceId    String
  timestamp   DateTime @default(now())
  pm25        Int?
  pm10        Int?
  tvoc        Int?
  co2         Int?
  temperature Float?
  humidity    Float?
  noise       Int?
  aqi         Int?
  messageId   String
  device      Device   @relation(fields: [deviceId], references: [id])

  // @@unique([deviceId, messageId]) REMOVED — deduplication now handled by Redis SETNX
  // in mqtt.consumer.ts before the DB write. Keeping this constraint would cause
  // B+ tree write amplification on every insert at scale.
  // The Redis key `dedup:{deviceId}:{messageId}` with 5-min TTL is the new dedup gate.

  // Primary access pattern: range scan by device within a time window
  @@index([deviceId, timestamp])
}

model GroupThreshold {
  id         String      @id @default(uuid())
  groupId    String      @unique
  thresholds Json
  createdAt  DateTime    @default(now())
  group      DeviceGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model DeviceThreshold {
  id         String   @id @default(uuid())
  deviceId   String   @unique
  thresholds Json
  createdAt  DateTime @default(now())
  device     Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

model AlertState {
  id              String    @id @default(uuid())
  userId          String
  deviceId        String
  parameter       String
  state           String
  lastTriggeredAt DateTime?
  updatedAt       DateTime  @updatedAt

  @@unique([userId, deviceId, parameter])
  // Alert evaluation reads current state filtered by deviceId + state value
  @@index([deviceId, state])
}

model EventLog {
  id        BigInt   @id @default(autoincrement())
  deviceId  String
  userId    String?
  eventType String
  parameter String?
  value     Float?
  createdAt DateTime @default(now())
  device    Device   @relation(fields: [deviceId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])

  // Composite covering indexes replace the two narrow single-column indexes.
  // These cover the WHERE + ORDER BY clauses used by the alert cooldown check
  // and both event log dashboard queries without heap fetches.
  @@index([deviceId, eventType, createdAt])
  @@index([userId, eventType, createdAt])
}

model Notification {
  id             String    @id @default(uuid())
  userId         String
  deviceId       String?
  message        String
  thresholdValue Float?
  createdAt      DateTime  @default(now())
  isRead         Boolean   @default(false)
  readAt         DateTime?
  user           User      @relation(fields: [userId], references: [id])

  // (userId, isRead) for unread count queries
  @@index([userId, isRead])
  // (userId, createdAt DESC) enables pagination ORDER BY without in-memory sort
  @@index([userId, createdAt])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([userId, revokedAt])
  @@index([token])
}

model Subscription {
  id               String           @id
  userId           String
  planId           String
  status           SubStatus        @default(ACTIVE)
  activatedAt      DateTime         @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?
  paymentId        String?
  orderId          String?          @unique
  method           SubMethod        @default(RAZORPAY)
  amountPaid       Float?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime
  SubscriptionPlan SubscriptionPlan @relation(fields: [planId], references: [id])
  User             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@index([userId])
}

model SubscriptionPlan {
  id           String         @id
  name         String         @unique
  amount       Float
  currency     String         @default("INR")
  durationDays Int
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime
  Subscription Subscription[]
}

enum DeviceStatus {
  ACTIVE
  WARNING
  OFFLINE
  ONLINE
}

enum SubMethod {
  RAZORPAY
  PHONEPE
}

enum SubStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum ReportType {
  CSV
  PDF
}

model GeneratedReport {
  id        String     @id // = BullMQ job.id (auto-generated)
  userId    String
  type      ReportType
  fileKey   String?    // logical key e.g. "reports/{id}.pdf" — path-agnostic for S3 migration
  createdAt DateTime   @default(now())
  expiresAt DateTime   // 24 hours from creation; cleanup scheduler removes expired files
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PremiumSubscription {
  id                 String    @id @default(uuid())
  userId             String
  activatedByAdminId String?
  activationDate     DateTime
  expiryDate         DateTime
  status             SubStatus @default(ACTIVE)
  revokedByAdminId   String?
  revokedReason      String?
  revokedAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  // Composite replaces two narrow single-column indexes.
  // expireOverdueSubscriptions() scans (status=ACTIVE, expiryDate < NOW()) — hits this index directly.
  @@index([status, expiryDate])
}

model PremiumHistory {
  id             String            @id @default(uuid())
  userId         String
  actionType     PremiumActionType
  previousExpiry DateTime?
  newExpiry      DateTime?
  adminId        String
  notes          String?
  createdAt      DateTime          @default(now())
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([adminId])
}

enum PremiumStatus {
  FREE
  PREMIUM
  EXPIRED
  REVOKED
  TRIAL
}

enum PremiumActionType {
  ACTIVATE
  RENEW
  REVOKE
}
